# Speech-to-text — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# LLM — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional override — leave empty to use pipecat's service default
ANTHROPIC_MODEL=

# Text-to-speech — https://play.cartesia.ai/
CARTESIA_API_KEY=
# Optional override — leave empty for the default voice (British Reading Lady)
CARTESIA_VOICE=

MAX_SESSION_SECS=600
IDLE_TIMEOUT_SECS=120

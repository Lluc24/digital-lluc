# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Pipecat Cloud (leave empty for local dev; then the app talks to a
# local bot over SmallWebRTC at LOCAL_BOT_WEBRTC_URL) ---
PIPECAT_CLOUD_AGENT_NAME=digital-lluc
PIPECAT_CLOUD_API_KEY=
LOCAL_BOT_WEBRTC_URL=http://localhost:7080/api/offer

# --- Usage cap (Upstash Redis; empty = no cap, local dev) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
DAILY_SESSION_CAP=5

# --- Session recordings admin (/admin/sessions) ---
# Vercel auto-injects BLOB_READ_WRITE_TOKEN when a *private* Blob store is
# connected to the project; the bot also needs this same token to upload
# recordings. Locally (no Vercel OIDC), set it explicitly to read them back.
BLOB_READ_WRITE_TOKEN=
# Only this email can view /admin/sessions.
ADMIN_EMAIL=

# Local dev only: skip login entirely (never set in production).
# Both are needed: the server flag skips the API session check, the
# NEXT_PUBLIC_ one skips the client-side login prompt.
# DEV_ALLOW_ANONYMOUS=1
# NEXT_PUBLIC_DEV_ALLOW_ANONYMOUS=1
